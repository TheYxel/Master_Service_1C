Процедура ОбработкаПроведения(Отказ, Режим)
	
	// ЭТАТ 1. РЕГИСТР СВЕДЕНИЙ: СОСТОЯНИЯ ЗАЯВОК (Строго 1 запись, вне циклов)
	Движения.СостоянияЗаявок.Записывать = Истина;
	ДвижениеСведений = Движения.СостоянияЗаявок.Добавить();
	ДвижениеСведений.Период = Дата;
	ДвижениеСведений.Заявка = Заявка;
	ДвижениеСведений.СтатусЗаявки = Перечисления.СтатусыЗаявок.Выполнена;
	ДвижениеСведений.Исполнитель = Исполнитель;  
	
	// ЭТАП 2. РЕГИСТР НАКОПЛЕНИЯ: ОСТАТКИ МАТЕРИАЛОВ (РАСХОД С ФИЛЬТРОМ УСЛУГ)
	Движения.ОстаткиМатериалов.Записывать = Истина;
	Для Каждого ТекСтрокаМатериалы Из Материалы Цикл 
		
		// Фильтруем немат. услуги
		Если ТекСтрокаМатериалы.Номенклатура.ТипыНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
			Продолжить;
		КонецЕсли;
		
		ДвижениеСклада = Движения.ОстаткиМатериалов.Добавить();
		ДвижениеСклада.ВидДвижения = ВидДвиженияНакопления.Расход;
		ДвижениеСклада.Период = Дата;
		ДвижениеСклада.Номенклатура = ТекСтрокаМатериалы.Номенклатура;
		ДвижениеСклада.Склад = Склад;
		ДвижениеСклада.Количество = ТекСтрокаМатериалы.Количество;
		//ДвижениеСклада.Сумма = ТекСтрокаМатериалы.Сумма;
	КонецЦикла;

	// ЭТАП 3. ЗАПИСЬ СКЛАДА И КОНТРОЛЬ ОСТАТКОВ
	// Записываем складские расходы в базу ДО ТОГО, как считать выручку
	Движения.ОстаткиМатериалов.Записать(); 
	
	// Контролируем остатки только при оперативном проведении
	Если Режим = РежимПроведенияДокумента.Оперативный Тогда
		
		ЗапросОстатков = Новый Запрос;
		ЗапросОстатков.Текст = 
			"ВЫБРАТЬ
			|	ОстаткиМатериаловОстатки.Номенклатура.Наименование КАК НоменклатураНаименование,
			|	-ОстаткиМатериаловОстатки.КоличествоОстаток КАК Дефицит
			|ИЗ
			|	РегистрНакопления.ОстаткиМатериалов.Остатки(&МоментВремени, Склад = &ТекущийСклад) КАК ОстаткиМатериаловОстатки
			|ГДЕ
			|	ОстаткиМатериаловОстатки.КоличествоОстаток < 0"; // Ищем ушедшие в минус товары
		
		// Используем границу, чтобы запрос гарантированно увидел движения текущего документа
		ГраницаКонтроля = Новый Граница(МоментВремени(), ВидГраницы.Включая);
		ЗапросОстатков.УстановитьПараметр("МоментВремени", ГраницаКонтроля);
		ЗапросОстатков.УстановитьПараметр("ТекущийСклад", Склад);
		
		РезультатКонтроля = ЗапросОстатков.Выполнить(); 
		
		Если Не РезультатКонтроля.Пустой() Тогда
			Отказ = Истина; // Блокируем проведение, если найден дефицит
			
			ВыборкаМинусов = РезультатКонтроля.Выбрать();
			Пока ВыборкаМинусов.Следующий() Цикл
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Недостаточно товара """ + ВыборкаМинусов.НоменклатураНаименование + """ на складе! Не хватает: " + ВыборкаМинусов.Дефицит + " шт.";
				Сообщение.Сообщить();
			КонецЦикла;
			
			// Если склад ушел в минус, прерываем процедуру сразу — выручку считать не нужно!
			Возврат; 
		КонецЕсли;
		
	КонецЕсли;

	// ЭТАП 4. РЕГИСТР НАКОПЛЕНИЯ: ВЫПОЛНЕННЫЕ РАБОТЫ (ПРИХОД ВЫРУЧКИ)
	Движения.ВыполненныеРаботы.Записывать = Истина;
	Для Каждого ТекСтрокаМатериалы Из Материалы Цикл
		ДвижениеВыручки = Движения.ВыполненныеРаботы.Добавить();
		ДвижениеВыручки.ВидДвижения = ВидДвиженияНакопления.Приход;
		ДвижениеВыручки.Период = Дата;
		ДвижениеВыручки.Клиент = Заказчик;
		ДвижениеВыручки.Исполнитель = Исполнитель;
		ДвижениеВыручки.Номенклатура = ТекСтрокаМатериалы.Номенклатура;
		ДвижениеВыручки.Количество = ТекСтрокаМатериалы.Количество;
		ДвижениеВыручки.Сумма = ТекСтрокаМатериалы.Сумма;
	КонецЦикла;

КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ЗаявкаКлиента") Тогда
		// Заполнение шапки
		Исполнитель = ДанныеЗаполнения.Исполнитель;
		Заказчик = ДанныеЗаполнения.Клиент;
		Комментарий = ДанныеЗаполнения.Комментарий;
		Заявка = ДанныеЗаполнения.Ссылка;
		СтатусЗаявки = ДанныеЗаполнения.СтатусЗаявки;
	КонецЕсли;

КонецПроцедуры
